{
	"name": "social-media",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"preinstall": "pnpm dlx @aikidosec/safe-chain setup-ci",
		"postinstall": "lefthook install",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"lint:cache": "prettier --check . && eslint --cache .",
		"format": "prettier --write .",
		"lint:spell": "cspell \"src/**/*.{svelte,ts,js,css,html}\" \"*.config.{js,ts}\" \"README.md\"",
		"lefthook:precommit": "lefthook run pre-commit",
		"lefthook:prepush": "lefthook run pre-push",
		"prevent-main-commit": "tsx scripts/prevent-main-commit.ts",
		"update:latest": "pnpm update --latest"
	},
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1fa",
	"engines": {
		"node": ">=22.16.0"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"onFail": "error"
		}
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@faker-js/faker": "^10.4.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.56.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.5.2",
		"cspell": "^10.0.0",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"lefthook": "^2.1.5",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0"
	},
	"pnpm": {
		"overrides": {
			"@clerk/backend": "3.2.3",
			"esbuild": ">=0.25.0",
			"cookie": ">=0.7.0",
			"devalue": ">=5.6.4",
			"picomatch": ">=4.0.4",
			"smol-toml": ">=1.6.1",
			"brace-expansion": ">=5.0.5",
			"lodash": "4.18.0",
			"browser-tabs-lock>lodash": "4.18.0",
			"vite": "8.0.5"
		}
	},
	"dependencies": {
		"@clerk/backend": "3.2.4",
		"@clerk/clerk-js": "^6.4.0",
		"@libsql/client": "^0.17.2",
		"devalue": "^5.6.4",
		"dotenv": "^17.4.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"drizzle-zod": "^0.8.3",
		"svelte-clerk": "^1.1.1",
		"utf-8-validate": "^6.0.6",
		"zod": "^4.3.6"
	},
	"ignoredBuiltDependencies": [
		"@clerk/shared"
	]
}
