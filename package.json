{
	"name": "social-media",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"lint:cache": "prettier --check . && eslint --cache .",
		"format": "prettier --write .",
		"lint:spell": "cspell \"src/**/*.{svelte,ts,js,css,html}\" \"*.config.{js,ts}\" \"README.md\"",
		"lefthook:precommit": "lefthook run pre-commit",
		"lefthook:prepush": "lefthook run pre-push",
		"prevent-main-commit": "tsx scripts/prevent-main-commit.ts",
		"update:latest": "pnpm update --latest"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@faker-js/faker": "^10.4.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.5.0",
		"cspell": "^9.7.0",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"lefthook": "^2.1.4",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.1",
		"vite": "^8.0.2"
	},
	"pnpm": {
		"overrides": {
			"esbuild": ">=0.25.0",
			"cookie": ">=0.7.0",
			"devalue": ">=5.6.4",
			"picomatch": ">=4.0.4",
			"smol-toml": ">=1.6.1",
			"brace-expansion": ">=5.0.5"
		}
	},
	"dependencies": {
		"@libsql/client": "^0.17.2",
		"dotenv": "^17.3.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.1",
		"drizzle-zod": "^0.8.3",
		"zod": "^4.3.6"
	}
}
